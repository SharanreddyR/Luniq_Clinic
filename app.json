{
  "expo": {
    "owner": "luniqcare",
    "name": "Luniq Clinic",
    "slug": "luniq-clinic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "luniq-clinic",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/brand-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2B2B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.luniqcare.clinicapp",
      "googleServicesFile": "./credentials/GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleDisplayName": "Luniq Clinic",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D2B2B"
      },
      "package": "com.luniqcare.clinicapp",
      "googleServicesFile": "./credentials/google-services.json",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./plugins/withAndroidFirebaseMessagingManifestMerger.js",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#2ebdb4",
          "defaultChannel": "luniq_clinic_default",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a8747032-54ba-4867-8b6e-5d7bddd86b04"
      }
    }
  }
}
